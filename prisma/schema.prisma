generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PersonaKey {
  alex
  max
}

enum ResponsibilityStatus {
  unassigned
  active
  needs_review
  paused
  not_relevant
  archived
}

enum AssignmentRole {
  accountable_owner
  shared_owner
  helper
  backup
}

enum AssignmentScope {
  outcome
  part
  support
  temporary
}

enum Visibility {
  private
  shared_household
  partner_visible
  check_in_only
}

enum Cadence {
  daily
  weekly
  monthly
  seasonal
  event_based
  as_needed
  one_time
}

enum HiddenEffortKey {
  noticing
  planning
  doing
  follow_through
  emotional_attention
}

enum RadarReasonKey {
  unclear_expectation
  blocked
  too_much
  handoff_needed
  review_due
  other
}

enum Urgency {
  low
  normal
  soon
}

enum RadarState {
  draft
  open
  scheduled
  discussed
  resolved
  dismissed
  deferred
}

enum CheckInState {
  draft
  scheduled
  active
  completed
  skipped
}

enum CheckInItemState {
  queued
  discussed
  deferred
  skipped
}

enum CheckInItemType {
  responsibility
  radar
  custom
}

enum DecisionType {
  assign_owner
  change_role
  change_standard
  change_cadence
  pause
  mark_not_relevant
  archive
  schedule_review
  custom_note
}

enum SourceReviewStatus {
  not_reviewed
  approved_original
  blocked
  needs_review
}

enum ResponsibilityBoardLane {
  cards_of_concern
  player_1
  player_2
  kid_split
  not_in_play
  trimmed
}

enum AiCardDraftStatus {
  processing
  ready
  failed
  accepted
  canceled
}

enum AiCardGenerationStage {
  queued
  transcribing
  structuring
  generating_image
  saving_image
  ready
  failed
}

enum AiCardSourceInputType {
  text
  audio
}

model Household {
  id                 String                 @id @default(uuid())
  name               String
  usernameNormalized String                 @unique
  timezone           String
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  credential         HouseholdCredential?
  personas           Persona[]
  sessions           Session[]
  responsibilities   Responsibility[]
  radarItems         RadarItem[]
  checkIns           CheckIn[]
  decisions          Decision[]
  events             ResponsibilityEvent[]
  loadSnapshots      LoadSnapshot[]
  aiCardDrafts       AiCardDraft[]
}

model HouseholdCredential {
  id                String    @id @default(uuid())
  householdId       String    @unique
  passwordHash      String
  hashAlgorithm     String
  hashParamsVersion String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastRotatedAt     DateTime?
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Persona {
  id                               String                         @id @default(uuid())
  householdId                      String
  key                              PersonaKey
  displayName                      String
  avatarKey                        String?
  createdAt                        DateTime                       @default(now())
  updatedAt                        DateTime                       @updatedAt
  household                        Household                      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  selectedSessions                 Session[]
  createdResponsibilities          Responsibility[]               @relation("CreatedResponsibilities")
  createdAssignments               ResponsibilityAssignment[]     @relation("CreatedAssignments")
  assignments                      ResponsibilityAssignment[]     @relation("PersonaAssignments")
  createdRadarItems                RadarItem[]                    @relation("CreatedRadarItems")
  facilitatedCheckIns              CheckIn[]                      @relation("FacilitatedCheckIns")
  createdDecisions                 Decision[]                     @relation("CreatedDecisions")
  actedResponsibilityEvents        ResponsibilityEvent[]          @relation("ActedResponsibilityEvents")
  onboardingPreferences            PersonaOnboardingPreferences?
  createdAiCardDrafts              AiCardDraft[]                  @relation("CreatedAiCardDrafts")

  @@unique([householdId, key])
}

model PersonaOnboardingPreferences {
  id                            String    @id @default(uuid())
  personaId                     String    @unique
  welcomeDismissedAt            DateTime?
  crashCourseSkippedAt          DateTime?
  crashCourseCompletedAt        DateTime?
  crashCourseCurrentStep        Int       @default(0)
  crashCourseReplayRequestedAt  DateTime?
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  persona                       Persona   @relation(fields: [personaId], references: [id], onDelete: Cascade)
}

model Session {
  id                String    @id @default(uuid())
  householdId       String
  selectedPersonaId String?
  tokenHash         String    @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastSeenAt        DateTime  @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?
  userAgentHash     String?
  household         Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  selectedPersona   Persona?  @relation(fields: [selectedPersonaId], references: [id], onDelete: SetNull)

  @@index([householdId])
  @@index([expiresAt])
}

model Responsibility {
  id                    String                         @id @default(uuid())
  householdId           String
  createdByPersonaId    String
  templateId            String?
  title                 String
  summary               String?
  areaKeys              String[]
  hiddenEffortKeys      HiddenEffortKey[]
  cadence               Cadence
  relevantDays          String[]
  status                ResponsibilityStatus
  visibility            Visibility
  boardLane             ResponsibilityBoardLane           @default(cards_of_concern)
  boardSortOrder        Int                               @default(0)
  householdStandard     String?
  notes                 String?
  sourceDefinition      String?
  sourceConception      String?
  sourcePlanning        String?
  sourceExecution       String?
  sourceMinimumStandard String?
  sourceCoverAssetPath  String?
  lastReviewedAt        DateTime?
  nextReviewAt          DateTime?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  archivedAt            DateTime?
  household             Household                      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByPersona      Persona                        @relation("CreatedResponsibilities", fields: [createdByPersonaId], references: [id], onDelete: Cascade)
  template              ResponsibilityTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assignments           ResponsibilityAssignment[]
  lifecycleNotes        ResponsibilityLifecycleNotes?
  radarItems            RadarItem[]
  checkInItems          CheckInItem[]
  decisions             Decision[]
  events                ResponsibilityEvent[]
  acceptedAiCardDraft   AiCardDraft?                   @relation("AcceptedAiCardDraft")

  @@index([householdId])
  @@index([householdId, boardLane, boardSortOrder])
  @@index([status])
  @@index([templateId])
}

model AiCardDraft {
  id                       String                @id @default(uuid())
  householdId              String
  createdByPersonaId       String
  sourceInputType          AiCardSourceInputType
  inputText                String?
  audioBytes               Bytes?
  audioMimeType            String?
  audioTranscript          String?
  status                   AiCardDraftStatus     @default(processing)
  generationStage          AiCardGenerationStage @default(queued)
  failureCode              String?
  failureMessage           String?
  title                    String?
  summary                  String?
  areaKeys                 String[]
  hiddenEffortKeys         HiddenEffortKey[]
  cadence                  Cadence?
  definition               String?
  conception               String?
  planning                 String?
  execution                String?
  minimumStandard          String?
  imagePrompt              String?
  imageNegativePrompt      String?
  coverImageBytes          Bytes?
  coverImageMimeType       String?
  acceptedResponsibilityId String?               @unique
  readyAt                  DateTime?
  acceptedAt               DateTime?
  canceledAt               DateTime?
  audioDeletedAt           DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  household                Household             @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByPersona         Persona               @relation("CreatedAiCardDrafts", fields: [createdByPersonaId], references: [id], onDelete: Cascade)
  acceptedResponsibility   Responsibility?       @relation("AcceptedAiCardDraft", fields: [acceptedResponsibilityId], references: [id], onDelete: SetNull)

  @@index([householdId, status, createdAt])
  @@index([createdByPersonaId])
}

model ResponsibilityAssignment {
  id                    String          @id @default(uuid())
  responsibilityId      String
  personaId             String
  role                  AssignmentRole
  scope                 AssignmentScope
  startsAt              DateTime
  endsAt                DateTime?
  createdByPersonaId    String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  responsibility        Responsibility  @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)
  persona               Persona         @relation("PersonaAssignments", fields: [personaId], references: [id], onDelete: Cascade)
  createdByPersona      Persona         @relation("CreatedAssignments", fields: [createdByPersonaId], references: [id], onDelete: Cascade)

  @@index([responsibilityId, startsAt])
  @@index([personaId])
}

model ResponsibilityLifecycleNotes {
  id                              String         @id @default(uuid())
  responsibilityId                String         @unique
  noticeDecideNotes               String?
  planPrepareNotes                String?
  executeFollowThroughNotes       String?
  dependencies                    String?
  blockers                        String?
  supportNeeded                   String?
  handoffNotes                    String?
  createdAt                       DateTime       @default(now())
  updatedAt                       DateTime       @updatedAt
  responsibility                  Responsibility @relation(fields: [responsibilityId], references: [id], onDelete: Cascade)
}

model ResponsibilityTemplate {
  id                 String               @id @default(uuid())
  slug               String               @unique
  title              String
  summary            String
  areaKeys           String[]
  defaultCadence     Cadence
  hiddenEffortKeys   HiddenEffortKey[]
  sourceReviewStatus SourceReviewStatus
  contentVersion     String
  sourceCardId       String?                 @unique
  definition         String?
  conception         String?
  planning           String?
  execution          String?
  minimumStandard    String?
  coverAssetPath     String?
  defaultLane        ResponsibilityBoardLane @default(not_in_play)
  sourceVersion      String?
  importedAt         DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  responsibilities   Responsibility[]
}

model RadarItem {
  id                 String          @id @default(uuid())
  householdId        String
  responsibilityId   String?
  createdByPersonaId String
  topic              String
  notes              String?
  desiredTiming      String?
  reasonKey          RadarReasonKey
  urgency            Urgency
  visibility         Visibility
  state              RadarState
  targetCheckInId    String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  resolvedAt         DateTime?
  deferredUntil      DateTime?
  household          Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  responsibility     Responsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  createdByPersona   Persona         @relation("CreatedRadarItems", fields: [createdByPersonaId], references: [id], onDelete: Cascade)
  targetCheckIn      CheckIn?        @relation("TargetCheckInRadarItems", fields: [targetCheckInId], references: [id], onDelete: SetNull)
  checkInItems       CheckInItem[]

  @@index([householdId, state])
  @@index([createdByPersonaId, visibility])
}

model CheckIn {
  id                    String        @id @default(uuid())
  householdId           String
  state                 CheckInState
  scheduledFor          DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  facilitatorPersonaId  String?
  summary               String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  household             Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  facilitatorPersona    Persona?      @relation("FacilitatedCheckIns", fields: [facilitatorPersonaId], references: [id], onDelete: SetNull)
  items                 CheckInItem[]
  decisions             Decision[]
  targetedRadarItems    RadarItem[]    @relation("TargetCheckInRadarItems")

  @@index([householdId, state])
}

model CheckInItem {
  id                 String             @id @default(uuid())
  checkInId          String
  responsibilityId   String?
  radarItemId        String?
  itemType           CheckInItemType
  state              CheckInItemState
  promptKey          String
  response           String?
  decisionId         String?            @unique
  sortOrder          Int
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  checkIn            CheckIn            @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  responsibility     Responsibility?    @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  radarItem          RadarItem?         @relation(fields: [radarItemId], references: [id], onDelete: SetNull)
  decision           Decision?          @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@index([checkInId, sortOrder])
}

model Decision {
  id                 String          @id @default(uuid())
  householdId        String
  checkInId          String?
  responsibilityId   String?
  decisionType       DecisionType
  summary            String
  effectiveAt        DateTime
  reviewOn           DateTime?
  createdByPersonaId String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  household          Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  checkIn            CheckIn?        @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  responsibility     Responsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  createdByPersona   Persona         @relation("CreatedDecisions", fields: [createdByPersonaId], references: [id], onDelete: Cascade)
  checkInItem        CheckInItem?

  @@index([householdId])
}

model ResponsibilityEvent {
  id                 String          @id @default(uuid())
  householdId        String
  responsibilityId   String?
  actorPersonaId     String?
  eventType          String
  payload            Json
  occurredAt         DateTime
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  household          Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  responsibility     Responsibility? @relation(fields: [responsibilityId], references: [id], onDelete: SetNull)
  actorPersona       Persona?        @relation("ActedResponsibilityEvents", fields: [actorPersonaId], references: [id], onDelete: SetNull)

  @@index([householdId, occurredAt])
}

model LoadSnapshot {
  id                         String    @id @default(uuid())
  householdId                String
  periodStart                DateTime
  periodEnd                  DateTime
  computedAt                 DateTime
  ownerDistribution          Json
  sharedDistribution         Json
  areaDistribution           Json
  cadenceDistribution        Json
  reviewDueCount             Int
  radarOpenCount             Int
  pausedOrNotRelevantCount   Int
  hiddenEffortMix            Json
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  household                  Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, periodStart, periodEnd])
}

model AuthThrottle {
  id                 String    @id @default(uuid())
  usernameNormalized String
  ipHash             String
  failedAttemptCount Int       @default(0)
  windowStartedAt    DateTime
  throttledUntil     DateTime?
  lastAttemptAt      DateTime
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([usernameNormalized, ipHash])
  @@index([throttledUntil])
}

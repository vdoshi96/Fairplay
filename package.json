{
  "name": "fairplay",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run prisma:generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "assets:generate": "node --experimental-strip-types scripts/generate-visible-assets.mjs",
    "assets:generate-little-alex": "node --experimental-strip-types scripts/generate-little-alex-sprites.mjs",
    "assets:generate-little-alex-hair-colors": "node scripts/generate-little-alex-hair-colors.mjs",
    "assets:generate-little-alex-skin-tones": "node scripts/generate-little-alex-skin-tones.mjs",
    "assets:generate-ui": "node --experimental-strip-types scripts/generate-ui-assets.mjs",
    "test:e2e": "npm run build && playwright test",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay?schema=public} SHADOW_DATABASE_URL=${SHADOW_DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay_shadow?schema=public} prisma generate",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay?schema=public} SHADOW_DATABASE_URL=${SHADOW_DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay_shadow?schema=public} prisma validate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay?schema=public} SHADOW_DATABASE_URL=${SHADOW_DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay_shadow?schema=public} npm run db:shadow && DATABASE_URL=${DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay?schema=public} SHADOW_DATABASE_URL=${SHADOW_DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay_shadow?schema=public} prisma migrate dev",
    "prisma:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay?schema=public} SHADOW_DATABASE_URL=${SHADOW_DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay_shadow?schema=public} node --experimental-strip-types prisma/seed.ts",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:shadow": "node scripts/db/ensure-shadow-db.mjs",
    "db:wait": "DATABASE_URL=${DATABASE_URL:-postgresql://fairplay:fairplay_local_password@localhost:5432/fairplay?schema=public} node scripts/db/wait-for-db.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.7.0",
    "lucide-react": "^1.14.0",
    "matter-js": "^0.20.0",
    "nanoid": "^5.1.5",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.1",
    "jsdom": "^25.0.1",
    "postcss": "8.5.14",
    "prisma": "^6.7.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}

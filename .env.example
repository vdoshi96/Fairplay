# Copy to .env.local and replace placeholders with local or Vercel-provided values.
# Never commit .env.local, managed database credentials, or real session secrets.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
SESSION_SECRET="replace-with-at-least-32-random-bytes"
AUTH_COOKIE_NAME="fairplay_session"
APP_BASE_URL="http://localhost:3000"

# Qwen AI Task Manager text-only card generation
QWEN_CARD_MODEL="qwen3.6-max-preview"
QWEN_OPENAI_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
QWEN_CARD_API_KEY="replace-with-qwen-key-for-card-structuring"

# Optional OpenAI fallback for AI Task Manager text-only generation
AI_PROVIDER_FALLBACK_ENABLED="false"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_TEXT_MODEL="gpt-5-nano"
OPENAI_TEXT_API_KEY="replace-with-openai-key-for-card-structuring"
